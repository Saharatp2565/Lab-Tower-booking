rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Allow read access to rooms for everyone
    match /rooms/{roomId} {
      allow read: if true;
      allow write: if true;
    }
    
    // Allow read/write access to bookings
    match /bookings/{bookingId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
